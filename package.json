{
  "name": "stayd-banda",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:op": "op run --env-file=.env.local -- next dev",
    "build": "next build",
    "build:op": "op run --env-file=.env.local -- next build",
    "start": "next start",
    "start:op": "op run --env-file=.env.local -- next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run src/__tests__/e2e/",
    "db:generate": "drizzle-kit generate",
    "db:generate:op": "op run --env-file=.env.local -- drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:push:op": "op run --env-file=.env.local -- drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:studio:op": "op run --env-file=.env.local -- drizzle-kit studio",
    "test:browser": "playwright test --project=desktop-chrome",
    "test:browser:ui": "playwright test --ui"
  },
  "dependencies": {
    "@auth/core": "^0.41.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@react-pdf/renderer": "^4.3.2",
    "@vercel/postgres": "^0.10.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
